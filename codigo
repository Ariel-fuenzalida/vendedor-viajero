//--------------------RECORRIDOS--------------------------------



void *recorridoGrafo(void *arreglo)
{
    ruta *rutaActual = (ruta *)arreglo; // se castea el void* para usarlo como ruta
    int i = 0;
    int k;
    int repetido;


    if (rutasEncontradasParaSolucion >= 100) { // si se encuentran 100 rutas, no busca mas
        sem_post(&semaforo); // libera permiso antes de terminar el hilo
        return NULL;
    }

    rutaActual->rutasNodo[rutaActual->cantidadPasosR] = rutaActual->nodoA; // guarda el nodo actual
    objetivoMarca(rutaActual->nodoA, rutaActual); // si es objetivo marca el nodo

    if (validadorObjetivosCompletados(rutaActual) == 1) { // si paso por todos los objetivos, sirve la ruta

        sem_wait(&mutex); // entra a zona critica para guardar la ruta

        if (rutasEncontradasParaSolucion < 30) {
            rutasEncontradas[rutasEncontradasParaSolucion] = *rutaActual; // guarda una copia de la ruta
            rutasEncontradasParaSolucion++; // aumenta el contador
        }

        sem_post(&mutex); // sale de zona critica
        sem_post(&semaforo); // libera el permiso del semaforo porque el hilo termino

        return NULL;
    }

    for (i = 0; i < 30 && grafo[rutaActual->nodoA - 1][i] != -1; i++) { // recorre todos los vecinos del nodo actual

        if (rutasEncontradasParaSolucion >= 100) {	// si llego al limite se corta
            break;
        }

        repetido = 0; // sirve para saber si un nodo ya esta en la ruta

        for (k = 0; k <= rutaActual->cantidadPasosR; k++) {
            if (rutaActual->rutasNodo[k] == grafo[rutaActual->nodoA - 1][i]) {
                repetido = 1; // si el nodo ya fue visitado, se marca repetido
            }
        }

        if (rutaActual->cantidadPasosR < 29 && repetido == 0) { // si queda espacio y no se repitio, avanza

            ruta *rutaNueva = malloc(sizeof(ruta)); // se crea nueva ruta para el nuevo hilo

            if (rutaNueva != NULL) {
                *rutaNueva = *rutaActual; se copia la ruta actual para no modificar hilo padre 

                rutaNueva->nodoA = grafo[rutaActual->nodoA - 1][i]; // nuevo nodo sera el vecino encontrado
                rutaNueva->cantidadPasosR = rutaActual->cantidadPasosR + 1; // suma un paso

                sem_wait(&semaforo); // espera el permiso para crear nuevo hilo

                pthread_t hiloNuevo;
                pthread_create(&hiloNuevo, NULL, recorridoGrafo, rutaNueva); // aca se usa la recursividad con recorridoGrafo
				
				/*
					no se usa detach porque queremos esperar el hilo
					pthread_join deja el padre esperando hasta que hijo termine
				
                pthread_join(hiloNuevo, NULL);
            }
        }
    }

    sem_post(&semaforo); // libera el grafo cuando el hilo termina
    return NULL;
}








//-----------------------------------------------------



int main()
{
    pthread_t hiloPrincipal; 
    int i, j;

    lee_grafo(); // se lee el grafo desde archivo


    for (i = 0; i < 100; i++){
        rutasEncontradas[i].cantidadPasosR = -1; // se inicia en -1 para avisar que no hay ruta guardada 
    }

    sem_init(&semaforo, 0, 40); // inicializacion del semaforo
    sem_init(&mutex, 0, 1); // inicializacion del mutex
	
	/*
		no ocupamos detach, usamos join porque el main y los hilos padres esperan a que sus hilos hijos terminen
		nuestros semaforos controlan permisos solamente, no liberan hilos
	*/

	
    ruta *rutaInicial;
    rutaInicial = malloc(sizeof(ruta)); // reserva memoria para primera ruta

    rutaInicial->nodoA = nodoinicial; // comienza con el nodo inicial
    rutaInicial->cantidadPasosR = 0; // comienza con 0 pasos

    for (i = 0; i < 5; i++){
        rutaInicial->visitado[i] = 0; // se inicializa el arreglo de visitados en 0, es decir, no se ha visitado ningun nodo objetivo
    }

    sem_wait(&semaforo); // se espera a que el semaforo este disponible para guardar la ruta optima

    pthread_create(&hiloPrincipal, NULL, recorridoGrafo, rutaInicial);; // se crea el hilo inicial con la ruta inicial

    pthread_join(hiloPrincipal, NULL); // se espera a que el hilo principal termine       



    imprime_grafo(); // imprime el grafo

    imprimirTodasLasRutas(); // imprime todas las rutas

    imprimirMejorRuta(); // imprime la mejor ruta 

    return 0;
}
