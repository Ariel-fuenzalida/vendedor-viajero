#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <pthread.h>
#include <semaphore.h>


typedef struct {
   int nodoA; //nodo donde uno se encuentra
   int rutasNodo[30]; // rutas maximas que se pueden tomar
   int cantidadPasosR; // cuantos nodos pase
   int visitado[5]; // cuantos  nodos validos tengo, si es 1 es que fue visitado y si es 0 es que no fue visitado
} ruta;

ruta rutasEncontradas[30]; // arreglo donde se guardaran las rutas encontradas para la solucion
int rutasEncontradasParaSolucion = 0; // contador para rutas que se han encontrado 
int grafo [30][30];
int nodosarecorrer[5];
int nodoinicial;
sem_t semaforo; // semaforo para controlar el acceso a la ruta optima
sem_t mutex; // para controlar el acceso a las rutas 




void lee_grafo()
{
  FILE * arch;
  char linea  [160], * p, *q;
  int i=0,j,k;


  arch = fopen("grafo.csv","r");
  while ( fgets(linea,160,arch) != NULL)
  {
      if ( i==0) /* lee primera linea = Nodo inicial */
      {
	 nodoinicial = atoi(linea);
	 printf("nodo inicio  = %d \n", nodoinicial);
         i++;
       }else
	{ 
          linea[strlen(linea)-1]=';';     /* reemplaza el \n por ; para que el strtok tome el ultimo numero */		
	  if (i == 1)  /* Segunda linea = Nodos a recorrer */
          {
	     p = strtok(linea,";");   /* encuento el string anterior a un ; que corresponde al nodo */
             for(j=0;j<5;j++)	
	     {	
		nodosarecorrer[j] = atoi(p);     /* lo almaceno en el vector nodosarecorrer */
	        printf("%d \n",nodosarecorrer[j]);
		p = strtok(NULL,";");        /* busco el sigiente ; en el string */
	     }  
	     i++; 
	  } 
           else   /* Desde tercera linea , por cada nodo  lista  sus enlaces */
           {  
	     p = strtok(linea,";");  /* saco el nodo del string */
             j = atoi(p) - 1;
	     k = 0;
             while ((p =strtok(NULL,";")) != NULL)  /* busco cada nodo apuntado que está separado por ; */
	     {
		 grafo [j][k++]= atoi(p);    /* en la matriz grafo, dejo cada enlace del nodo */
	     }
	     grafo[j][k] = -1;  /* inserto al final de la fila un -1 para indicar que no hay mas enlace */
	   }
	}
  }
 }





void imprime_grafo()
{
   int i, j;
   for (i=0;i<30;i++)
   {
      printf("\n nodo %d -> ",i+1);	   
      for (j=0;grafo[i][j] != -1;j++)
	  printf(" - %d",grafo[i][j]);    

   }
}



//-------------------FUNCIONES AUXILIARES -----------------------------


int validarObjetivo(int nodoActual){// si es 1 es valido y si es 0 es invalido 
    int i =0;
    for (i=0; i<5; i++){
        if (nodoActual == nodosarecorrer[i]){
            return i;
            
        }
    }
    return -1;
}

void objetivoMarca(int numNodo, ruta *rutaVisitada){ //para marcar un nodo visitado
    int posicion = 0;

    posicion = validarObjetivo(numNodo);
    if (posicion != -1){ // marca el nopdo si es realmente valido o si realmente existe, es -1 porque podria haber un nodo en la posicion 0
        rutaVisitada->visitado[posicion] = 1; //marco el nodo
}
}


void imprimirMejorRuta()
{
    int i;
    int laMejor = 0;


    for (i = 1; i < rutasEncontradasParaSolucion; i++) {
        if (rutasEncontradas[i].cantidadPasosR < rutasEncontradas[laMejor].cantidadPasosR) {
            laMejor = i;
        }
    }

    printf("\nmejor ruta encontrada\n");
    imprimirRuta(&rutasEncontradas[laMejor]);
}


int validadorObjetivosCompletados(ruta *lista){ // validar que el nodo a llegar sea un nodo objetivo
    int i = 0;
    for (i = 0; i < 5; i++){
        if (0 == lista->visitado[i]){
            return 0; // si uno es 0, es que aun quedan objetivos que visitar
            break;
        }
    }
    return 1; // si se retorna 1 es porque ya se tienen todos los objetivos completos
} // se usa para terminar el recorrido de una si ya se tienen los 5 numeros

void imprimirRuta(ruta *r)
{
    int i;

    for (i = 0; i <= r->cantidadPasosR; i++) // imprime todos los nodos guardados en la ruta
    {
        if (i > 0)
        {
            printf(" -> ");
        }

        printf("%d", r->rutasNodo[i]);
    }

    printf(" | pasos: %d\n", r->cantidadPasosR); // imprime cuantos pasos tiene la ruta
}



void imprimirTodasLasRutas()
{
    int i;

    printf("\n----- TODAS LAS RUTAS ENCONTRADAS -----\n");

    for (i = 0; i < rutasEncontradasParaSolucion; i++) // solo recorre rutas que fueron encontradas
    {
        printf("\nRuta %d: ", i + 1);

        imprimirRuta(&rutasEncontradas[i]);
    }
}




